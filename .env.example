# Copia este archivo como ".env" y rellena tus propios valores.
# El archivo ".env" NUNCA debe subirse a GitHub (ya está en .gitignore).

# Cadena de conexión de tu clúster de MongoDB Atlas.
# La encuentras en Atlas: Database > Connect > Drivers
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/devfirst

# Cualquier cadena de texto larga y aleatoria, usada para firmar los JWT.
JWT_SECRET=cambia_esto_por_una_cadena_secreta_larga_y_aleatoria

# Puerto donde corre el servidor en local
PORT=4000
